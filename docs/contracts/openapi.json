            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Reap Leases Api V1 Admin Reap Leases Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Reap Leases",
        "tags": [
          "admin"
        ]
      }
    },
    "/api/v1/agents/status": {
      "get": {
        "description": "Retorna status agregado do agent do tenant.",
        "operationId": "get_agent_status_api_v1_agents_status_get",
        "parameters": [
          {
            "in": "query",
            "name": "tenant_id",
            "required": true,
            "schema": {
              "pattern": "^\\d{6}$",
              "title": "Tenant Id",
              "type": "string"
            }
          },
          {
            "in": "header",
            "name": "X-Tenant-Id",
            "required": true,
            "schema": {
              "title": "X-Tenant-Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentStatusResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Agent Status",
        "tags": [
          "agents"
        ]
      }
    },
