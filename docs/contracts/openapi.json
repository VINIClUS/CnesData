        "title": "HealthResponse",
        "type": "object"
      },
      "RegisterRequest": {
        "properties": {
          "agent_version": {
            "title": "Agent Version",
            "type": "string"
          },
          "competencia": {
            "maximum": 209912.0,
            "minimum": 200001.0,
            "title": "Competencia",
            "type": "integer"
          },
          "fonte_sistema": {
            "enum": [
              "CNES_LOCAL",
              "CNES_NACIONAL",
              "SIHD",
              "SIA_APA",
              "SIA_BPI",
              "BPA_C",
              "BPA_I"
            ],
            "title": "Fonte Sistema",
            "type": "string"
          },
          "job_id": {
            "format": "uuid",
            "title": "Job Id",
            "type": "string"
          },
          "machine_id": {
            "title": "Machine Id",
            "type": "string"
          },
          "tenant_id": {
            "pattern": "^\\d{6}$",
            "title": "Tenant Id",
            "type": "string"
          },
          "tipo_extracao": {
            "title": "Tipo Extracao",
            "type": "string"
          }
        },
        "required": [
          "tenant_id",
          "fonte_sistema",
          "tipo_extracao",
          "competencia",
          "job_id",
          "agent_version",
          "machine_id"
        ],
        "title": "RegisterRequest",
        "type": "object"
      },
      "RegisterResponse": {
        "properties": {
          "extraction_id": {
            "format": "uuid",
            "title": "Extraction Id",
            "type": "string"
          },
          "upload_url": {
            "title": "Upload Url",
            "type": "string"
          }
        },
        "required": [
          "extraction_id",
          "upload_url"
        ],
        "title": "RegisterResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
