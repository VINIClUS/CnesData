{
  "$defs": {
    "JobStatus": {
      "enum": [
        "PENDING",
        "UPLOADED",
        "PROCESSING",
        "INGESTED",
        "FAILED",
        "DLQ"
      ],
      "title": "JobStatus",
      "type": "string"
    }
  },
  "properties": {
    "agent_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Version"
    },
    "competencia": {
      "maximum": 209912,
      "minimum": 200001,
      "title": "Competencia",
      "type": "integer"
    },
    "completed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "error_detail": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Detail"
    },
    "fonte_sistema": {
      "enum": [
        "CNES_LOCAL",
        "CNES_NACIONAL",
        "SIHD",
        "SIA_APA",
        "SIA_BPI",
        "BPA_C",
        "BPA_I"
      ],
      "title": "Fonte Sistema",
      "type": "string"
    },
    "id": {
      "format": "uuid",
      "title": "Id",
      "type": "string"
    },
    "job_id": {
      "format": "uuid",
      "title": "Job Id",
      "type": "string"
    },
    "lease_owner": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lease Owner"
    },
    "lease_until": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Lease Until"
    },
    "machine_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Machine Id"
    },
    "object_key": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Object Key"
    },
    "retry_count": {
      "default": 0,
      "minimum": 0,
      "title": "Retry Count",
      "type": "integer"
    },
    "row_count": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Row Count"
    },
    "schema_version": {
      "default": 1,
      "minimum": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "sha256": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sha256"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "$ref": "#/$defs/JobStatus"
    },
    "tenant_id": {
      "pattern": "^\\d{6}$",
      "title": "Tenant Id",
      "type": "string"
    },
    "tipo_extracao": {
      "title": "Tipo Extracao",
      "type": "string"
    },
    "uploaded_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Uploaded At"
    }
  },
  "required": [
    "id",
    "job_id",
    "tenant_id",
    "fonte_sistema",
    "tipo_extracao",
    "competencia",
    "status",
    "created_at"
  ],
  "title": "Extraction",
  "type": "object"
}
