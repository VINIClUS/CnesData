[run]
branch = true
source =
    dump_agent
    data_processor
    central_api
    cnes_db_migrator
omit =
    **/__pycache__/**
    **/tests/**

[report]
# TODO(apps-coverage): elevar para 90 ao cobrir platform_runtime.py
# (posix/win32 duals) e worker/consumer.py (loop async). Base 78% em 2026-04-17.
fail_under = 75
show_missing = true
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @overload
    raise NotImplementedError
