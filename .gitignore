# =============================================================================
# CnesData — .gitignore
# Padrão: Ambientes Python, dados sensíveis e arquivos de IDE
# =============================================================================

# --- Ambiente Virtual ---
env/
venv/
.venv/
ENV/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.spec

# --- Pytest ---
.pytest_cache/
.cache/
htmlcov/
.coverage
coverage.xml

# --- Dados e Relatórios Gerados ---
# Os arquivos gerados são resultado do pipeline e não devem ir ao Git.
data/
logs/

# --- Credenciais e Configuração Local ---
# NUNCA versione o .env!
.env
*.env
!.env.example

# --- VSCode ---
.vscode/
.claudeignore.json
.streamlit/
escalidraw.log

# --- Sistema Operacional ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Arquivos de Benchmark ---
macro.json
out.json
.benchmarks/

# --- Arquivos Temporários de Debug ---
*.txt.bak
win_test*.txt
intersect*.txt
*_out.txt
export_log.txt
output.txt
.worktrees/
.playwright/
.ruff_cache/
.streamlit/
docs/superpowers/
excalidraw.log
.streamlit/
.coverage.xml.gz
.coverage.xml.gz.part
.coverage.xml.gz.part.1
docs/superpowers/**
docs/superpowers
docs/superpowers/*
.superpowers\brainstorm
.vscode
.serena
docs/specs/*
docs/specs/
docs/specs/**

# Claude
.claudeignore


# Visual brainstorming companion
.superpowers/

# --- Node (headroom-ai MCP) ---
node_modules/
package-lock.json
package.json

# Post-cutover
apps/dump_agent_go/coverage.out
apps/dump_agent_go/coverage.filtered.out
apps/dump_agent_go/dumpagent.exe
*.fbk

# --- Firebird 1.5.6 Embedded Cache ---
.cache/firebird-1.5.6/
